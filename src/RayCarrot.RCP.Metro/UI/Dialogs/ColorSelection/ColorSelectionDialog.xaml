<local:WindowContentControl x:Class="RayCarrot.RCP.Metro.ColorSelectionDialog"
                            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                            xmlns:local="clr-namespace:RayCarrot.RCP.Metro"
                            xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                            ResxExtension.DefaultResxName="{x:Static local:LocalizationManager.ResourcePath}"
                            Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                            Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                            mc:Ignorable="d"
                            Height="400"
                            Width="600"
                            d:DataContext="{d:DesignInstance local:ColorSelectionViewModel}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <local:Card Grid.Row="0"
                    Margin="{StaticResource RCP.Thicknesses.Card}">
            <!-- TODO-LOC -->
            <mah:ColorCanvas SelectedColor="{Binding Path=SelectedColor}" />
        </local:Card>

        <Grid Grid.Row="1"
              Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="{Resx Cancel}"
                    Click="CancelButton_Click" 
                    Style="{StaticResource RCP.Styles.Button.Default}" 
                    Margin="0 0 8 0" />

            <Button Grid.Column="2"
                    Content="{Resx Accept}"
                    Click="OKButton_Click" 
                    Style="{StaticResource RCP.Styles.Button.Accent}" 
                    IsDefault="True" />
        </Grid>

    </Grid>
</local:WindowContentControl>