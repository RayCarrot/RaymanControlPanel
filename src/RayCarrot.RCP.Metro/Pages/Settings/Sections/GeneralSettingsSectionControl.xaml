<UserControl x:Class="RayCarrot.RCP.Metro.Pages.Settings.Sections.GeneralSettingsSectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:rcp="clr-namespace:RayCarrot.RCP.Metro"
             xmlns:sections="clr-namespace:RayCarrot.RCP.Metro.Pages.Settings.Sections"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DesignWidth="500"
             ResxExtension.DefaultResxName="{x:Static rcp:LocalizationManager.ResourcePath}"
             d:Background="{DynamicResource RCP.Brushes.Card.SecondaryBackground}"
             d:Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" 
             d:DataContext="{d:DesignInstance sections:GeneralSettingsSectionViewModel}">
    <StackPanel>
        <StackPanel>
            <CheckBox Content="{Resx Settings_GeneralCloseOnLaunch}"
                      IsChecked="{Binding Path=Data.App_CloseAppOnGameLaunch}"
                      Margin="0 0 0 8" />

            <CheckBox Content="{Resx Settings_CheckForRunningGames}"
                      IsChecked="{Binding Path=CheckForRunningGames}"
                      Margin="0 0 0 8" />

            <CheckBox Content="{Resx Settings_UseDiscordRichPresence}"
                      ToolTip="{Resx Settings_UseDiscordRichPresenceInfo}"
                      IsChecked="{Binding Path=UseDiscordRichPresence}"
                      Margin="0 0 0 8" />

            <CheckBox Content="{Resx Settings_GetBetaUpdates}"
                      IsChecked="{Binding Path=Data.Update_GetBetaUpdates}"
                      rcp:UserLevelAssist.MinUserLevel="Technical"
                      Margin="0 0 0 8" />

            <StackPanel rcp:UserLevelAssist.MinUserLevel="Technical">

                <StackPanel Orientation="Horizontal"
                            Margin="0 0 0 4">
                    <TextBlock Style="{StaticResource RCP.Styles.TextBlock.Header}"
                               Text="{Resx Settings_SerializationLog}" />

                    <rcp:InfoIcon Text="{Resx Settings_SerializationLogInfo}" />

                </StackPanel>

                <CheckBox Content="{Resx IsEnabled}" 
                          IsChecked="{Binding Path=Data.Binary_IsSerializationLogEnabled}"
                          Margin="0 0 0 4" />

                <rcp:BrowseBox Visibility="{Binding Path=Data.Binary_IsSerializationLogEnabled, Converter={rcp:BooleanToVisibilityConverter}}"
                               FileFilter="Txt (*.txt)|*.txt"
                               SelectedPath="{Binding Path=Data.Binary_BinarySerializationFileLogPath}"
                               BrowseType="SaveFile"
                               Margin="0 0 0 8" />

            </StackPanel>
        </StackPanel>

        <TextBlock Style="{StaticResource RCP.Styles.TextBlock.Header}"
                   Text="{Resx Settings_General_JumpListHeader}"
                   Margin="0 0 0 4" />

        <StackPanel>

            <Button HorizontalAlignment="Left"
                    HorizontalContentAlignment="Left"
                    Content="{Resx Settings_EditJumpList}"
                    ToolTip="{Resx Settings_EditJumpListInfo}"
                    Command="{Binding Path=EditJumpListCommand, Mode=OneTime}"
                    rcp:Icon.Kind="PencilBoxOutline" 
                    Style="{StaticResource RCP.Styles.Button.Default}"
                    Margin="0 0 0 4" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <mah:ClipBorder Grid.Column="0"
                                HorizontalAlignment="Left"
                                CornerRadius="{StaticResource CornerRadius.Default}" 
                                Height="250"
                                Margin="0 0 0 4">
                    <Image Source="JumpList.png" 
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </mah:ClipBorder>

                <rcp:AprilFoolsGif Grid.Column="1"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Asset="RabbidHelico"
                                   Height="100" 
                                   Margin="100 0 0 0"
                                   FlashMargin="104 -16 0 0"
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Left"
                                   RenderTransformOrigin="0.5,0.5">
                    <rcp:AprilFoolsGif.RenderTransform>
                        <ScaleTransform ScaleX="-1"/>
                    </rcp:AprilFoolsGif.RenderTransform>
                </rcp:AprilFoolsGif>

            </Grid>

            <TextBlock Text="{Resx Settings_General_JumpListImageCaption}" 
                       FontStyle="Italic" 
                       Margin="0 0 0 8" />

        </StackPanel>

    </StackPanel>

</UserControl>